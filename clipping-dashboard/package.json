{
  "name": "clipping-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "VITE_USE_FUNCTIONS_EMULATOR=true VITE_SKIP_STORAGE_UPLOAD=true vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "firebase:login": "firebase login --no-localhost",
    "firebase:emulators:functions": "firebase emulators:start --only functions",
    "firebase:deploy:functions": "firebase deploy --only functions:generateClips",
    "firebase:secrets:set:openai": "firebase functions:secrets:set OPENAI_API_KEY"
  },
  "dependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "firebase": "^12.10.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.8.0",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1"
  }
}
