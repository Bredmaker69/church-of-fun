OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Optional local stable-ts alignment provider
STABLE_TS_LOCAL_ENABLED=true
STABLE_TS_PYTHON_BIN=python3
STABLE_TS_MODEL=large-v3-turbo
STABLE_TS_TIMEOUT_MS=420000
STABLE_TS_FORCE_ARM64=true
STABLE_TS_DISABLE_OPENAI_FALLBACK=true
# Optional CA bundle path for model download TLS trust:
# STABLE_TS_CA_BUNDLE="/absolute/path/to/cacert.pem"
# Optional local-dev bypass when corporate/self-signed cert chain blocks downloads:
# STABLE_TS_INSECURE_MODEL_DOWNLOAD=true
# Example when using the setup script:
# STABLE_TS_PYTHON_BIN="/absolute/path/to/clipping-dashboard/functions/.venv-stable-ts/bin/python"
# STABLE_TS_DEVICE=cpu
# STABLE_TS_COMPUTE_TYPE=float32
# STABLE_TS_ALIGN_SCRIPT=/absolute/path/to/functions/scripts/stable_ts_align.py
